@using System
@using System.Globalization

@{
    ViewData["Title"] = "User Enrollment"; 
}
@* <link href="~/lib/bootstrap/dist/css/datatables.min.css" rel="stylesheet"> *@
<script src="~/lib/jquery/dist/datatables.min.js"></script>

<div class="container-fluid">
    <div class="border rounded" style="padding:2%;box-shadow: 1px 1px 5px 1px #b2b1b1">
    <h3>User Enrollment</h3>
        <div class="col-14" style="width:50%;">
            <form>
                @Html.AntiForgeryToken()
                <div >
                    <div class="input-group m-2">
                        <label for="fieldUserType" class="col-4">User Type: </label>
                        <select id="fieldUserType" class="form-control">
                            @model List<_VEHRSv1.Models.AspNetRole>
                            @if ((this.User.IsInRole("SYSADMIN") || this.User.IsInRole("APPADMIN") || this.User.IsInRole("USER")) && User.Identity.IsAuthenticated)
                            {
                                foreach (var role in Model)
                                {
                                        <option value="@role.Name">@role.Name</option>  
                                }
                            }
                        </select>
                    </div>
                    <div class="input-group m-2">
                        <label for="fieldUserId" class="col-4">User ID<span class="text-danger">*</span> :</label>
                        <input id="fieldUserId" type="text" class="form-control"  />
                    </div>
                    <div class="input-group m-2">
                        <label for="fieldLastName" class="col-4">Last Name : </label>
                        <input id="fieldLastName" type="text" class="form-control" disabled/>
                    </div>
                    <div class="input-group m-2">
                        <label for="fieldFirstName" class="col-4">First Name : </label>
                        <input id="fieldFirstName" type="text" class="form-control" disabled />
                    </div>
                    <div class="input-group m-2">
                        <label for="fieldMiddleInitial" class="col-4">Middle Initial :</label>
                        <input id="fieldMiddleInitial" type="text" class="form-control" disabled />
                    </div>
                    <div class="input-group m-2">
                        <label for="fieldDepartment" class="col-4">Department/Division :</label>
                        <input id="fieldDepartment" type="text" class="form-control" disabled />
                    </div>
                    <div class="input-group m-2" style="">
                        <label for="fieldJobTitle" class="col-4">Job Title : </label>
                        <input id="fieldJobTitle" class="form-control" disabled />
                    </div>
                </div>
               
            </form>
        </div>
        <div>
            <input type="button" class="btn btn-success" id="btnEnrollUser" value="Enroll" />
            <input type="button" class="btn btn-primary" id="btnUpdateUser" value="Save" style="display: none;" />
            <input type="button" class="btn btn-danger" id="btnCancelMode" value="Cancel">
        </div>
    </div>
        <br/>
    <div>
        <table id="usersTable" class="table" style="width:100%">
            <thead class="w-auto thead-dark">
                <tr >
                    <th style="width:7%;">User ID</th>
                    <th style="width:15%;">First Name</th>
                    <th style="width:15%;">Last Name</th>
                    <th style="width:5%;">MI</th>
                    <th style="width:15%;">Job Title</th>
                    <th style="width:15%;">Department/Division</th>
                    <th style="width:10%;">User Type</th>
                    <th style="width:auto;" scope="col">Option</th>
                    @* <th style="width:auto;"></th> *@
                </tr>
            </thead>
            <tbody id="usersTableBody" ></tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="modalSystemMessage" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5>System Message</h5>
            </div>

            <div class="modal-body">
                <span id="txtSystemMessage"></span>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalConfirmDelete" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5>System Message</h5>
            </div>

            <div class="modal-body">

                <span>Are you sure you want to delete this user?</span>
                <div class="input-group m-2">
                    <div class="row w-100">
                        <div class="col-sm-3" style="margin-right:-10%">
                            <label for="fieldUserIdmodal">User ID:</label>
                        </div>
                        <div class="col-sm-8" style="margin-top:-1.5%">
                            <input id="fieldUserIdmodal" type="text" class="form-control-plaintext" disabled />
                        </div>
                    </div>
                </div>

                <div class="input-group m-2" >
                    <div class="row w-100" style="margin-top:-3%">
                        <div class="col-sm-3" style="margin-right:-10%">
                            <label for="fieldNameIdmodal">Name:</label>
                        </div>
                        <div class="col-sm-8" style="margin-top:-1.5%">
                            <input id="fieldNameIdmodal" type="text" class="form-control-plaintext" disabled />
                        </div>
                    </div>
                </div>

                <div class="input-group m-2">
                    <div class="row w-100" style="margin-top:-3%">
                        <div class="col-sm-3" style="margin-right:-10%">
                            <label for="fieldTilemodal">Job Title:</label>
                        </div>
                        <div class="col-sm-8" style="margin-top:-1.5%">
                            <input id="fieldTilemodal" type="text" class="form-control-plaintext" disabled />
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer d-flex justify-content-evenly">
                <button class="btn btn-success d-flex" id="btnConfirmDelete" style="padding-left: 40px;padding-right: 40px;" data-bs-dismiss="modal">Yes</button>
                <button class="btn btn-danger d-flex" style="padding-left: 40px;padding-right: 40px;" data-bs-dismiss="modal">No</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalConfirmUpdate" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5>System Message</h5>
            </div>

            <div class="modal-body">
                <span></span>
                <span>Are you sure you want to update this user?</span>
            </div>

            <div class="modal-footer d-flex justify-content-evenly">
                <button class="btn btn-success d-flex" id="btnConfirmUpdate" style="padding-left: 40px;padding-right: 40px;" data-bs-dismiss="modal">Yes</button>
                <button class="btn btn-danger d-flex" style="padding-left: 40px;padding-right: 40px;" data-bs-dismiss="modal">No</button>
            </div>
        </div>
    </div>
</div>




<script src="~/js/Enrollment/_Userenrollment.js">
</script>