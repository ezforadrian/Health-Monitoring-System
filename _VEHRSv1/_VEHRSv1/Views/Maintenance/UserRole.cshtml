@using System
@using System.Globalization
@{
    ViewData["Title"] = "User Enrollment";
}
 @* <link href="~/lib/bootstrap/dist/css/datatables.min.css" rel="stylesheet"> *@
<script src="~/lib/jquery/dist/datatables.min.js"></script>
<h3>USER ROLES</h3>
<br/>
<div class="border rounded" style="padding:2%;box-shadow: 1px 1px 5px 1px #b2b1b1">
 <form class="row col-14">
@Html.AntiForgeryToken()

        <div class="input-group">
            <div class="input-group m-2 m-2">
                <label for="fieldRoleName" class="col-2">Role Name<span class="text-danger">*</span> :</label>
                <input id="fieldRoleName" type="text" class="form-control"/>
        
            </div>
            <div class="input-group m-2 m-2">
                <label for="fieldNormalizeName" class="col-2">Normalize Name<span class="text-danger">*</span> :</label>
                <input id="fieldNormalizeName" type="text" class="form-control" />

            </div>
        </div>
        </form>
        <br />
        <div>
            <input type="button" class="btn btn-success" id="btnAddRole" value="Add" />
            <input type="button" class="btn btn-danger" id="btnCancel" value="Cancel" />

        </div>
</div>
<br/>
<div>
    <table id="rolesTable" class="table table-sm">
        <thead class="w-auto thead-dark">
            <tr class="table-active">
                <th style="width:20%;">ID</th>
                <th style="width:20%;">Role Name</th>
                <th style="width:20%;">Normalize Name</th>
                <th style="width:20%;" >Option</th>
                @* <th style="width:auto;"></th> *@
            </tr>
        </thead>
        <tbody id="rolesTableBody" ></tbody>
    </table>
</div>

<div class="modal fade" id="modalSystemMessage" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5>System Message</h5>
            </div>

            <div class="modal-body">
                <span id="txtSystemMessage"></span>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalConfirmDelete" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5>System Message</h5>
            </div>

            <div class="modal-body">

                <span>Are you sure you want to delete this user?</span>
                <div class="input-group m-2">
                    <div class="row w-100">
                        <div class="col-sm-4" style="margin-right:-15%">
                            <label for="fieldRoleNamemodal">Role Name:</label>
                        </div>
                        <div class="col-sm-4" style="margin-top:-1.5%">
                            <input id="fieldRoleNamemodal" type="text" class="form-control-plaintext" disabled />
                        </div>
                    </div>
                </div>

                <div class="modal-footer d-flex justify-content-evenly">
                    <button class="btn btn-success d-flex" id="btnConfirmDelete" style="padding-left: 40px;padding-right: 40px;" data-bs-dismiss="modal">Yes</button>
                    <button class="btn btn-danger d-flex" style="padding-left: 40px;padding-right: 40px;" data-bs-dismiss="modal">No</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/js/Maintenance/_addRole.js"></script>