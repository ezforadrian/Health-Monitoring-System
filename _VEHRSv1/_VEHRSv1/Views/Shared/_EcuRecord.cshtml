@model vmEmployeeHealthRecord

<br />

<button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addDetailModal" data-action="add">
    Add ECU Record
</button>

<div>
    <br />
    <table id="ecuDetailsTable" class="table table-striped table-hover" style="width:100%">
        <thead>
            <tr>
                <th>#</th>
                <th>ECU Date</th>
                <th>Branch</th>
                <th>Finding(s)</th>
                <th>Remarks</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.VmEcuHeaders.Any())
            {
                var recordIndex = 1;

                foreach (var ecuHeader in Model.VmEcuHeaders)
                {
                    <tr>
                        <td>@recordIndex</td>
                        <td>@ecuHeader.Ecudate.ToString("yyyy-MM-dd")</td>
                        <td>@ecuHeader.Branch</td>
                        <td>

                            @if (ecuHeader.Ecudetails != null && ecuHeader.Ecudetails.Any())
                            {
                                var resCount = 0;

                                @foreach (var test in ecuHeader.Ecudetails)
                                {
                                    if (test.Result == true)
                                    {
                                        resCount++; 
                                        @test.TestName <br />
                                    }
                                    
                                }

                                if (resCount == 0)
                                {
                                    @: Normal Findings
                                }
                            }
                            
                        </td>
                        <td>@ecuHeader.Remarks</td>
                        <td>
                            <button class="btn btn-primary" onclick="editEcuDetail('@Model.EmpIdNumberEnc','@ecuHeader.EcuHeaderIdEnc')">Edit</button>
                        </td>
                    </tr>

                    recordIndex++;
                }
            }

        </tbody>
    </table>
</div>

<!-- Add Ecu Detail Modal -->
<div class="modal fade" id="addDetailModal" tabindex="-1" aria-labelledby="addDetailModalLabel" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addDetailModalLabel">Add ECU Record</h5>
            </div>
            <div class="modal-body">
                <form id="addEcuForm" method="post" autocomplete="off">
                    <input type="hidden" name="IdEnc" id="IdEnc" value="@Model.EmpIdNumberEnc" />
                    <div class="form-group">
                        <label for="EcuDate">ECU Date</label>
                        <input type="date" class="form-control" name="EcuDate" id="EcuDate" required />
                    </div>

                    <div class="form-group">
                        <label for="BranchCodeEnc">Branch</label>
                        <select class="form-control" name="BranchCodeEnc" id="BranchCodeEnc" required></select>
                    </div>

                    <div class="form-group">
                        <label for="Findings">Findings</label>
                        <div class="form-group" id="findingsContainer">
                            @if (Model != null && Model.VmTestDetails.Any())
                            {
                                foreach (var detail in Model.VmTestDetails)
                                {
                                    <div id="@detail.TestIdEnc" class="form-check">
                                        <input type="checkbox" name="TestIdEnc" value="@detail.TestIdEnc" class="test-detail-checkbox" />
                                        <label class="form-check-label" for="TestIdEnc">@detail.TestName</label>
                                    </div>
                                }
                            }
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="Remarks">Remarks</label>
                        <textarea class="form-control" id="Remarks" name="Remarks"></textarea>
                    </div>

                    <hr />
                    <div class="form-group">
                        <label for="Summary">Summary:</label>
                        <div id="findingsSummary">Normal Findings</div>
                    </div>
                    <div id="errorList" class="text-danger mt-2"></div>

                    
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="confirmSaveDetailBtn" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addEcuConfirmationModal">Save Detail</button>
            </div>
        </div>
    </div>
</div>

<!-- Edit Ecu Detail Modal -->
<div class="modal fade" id="editDetailModal" tabindex="-1" aria-labelledby="editDetailModalLabel" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editDetailModalLabel">Edit Ecu Record</h5>
            </div>
            <div class="modal-body">
                <form id="editEcuForm" method="post" autocomplete="off">
                    <input type="hidden" id="EditEmpIdEnc" />
                    <input type="hidden" id="EditEcuHeaderIdEnc" />
                    <div class="form-group">
                        <label for="EcuDate">ECU Date</label>
                        <input type="date" class="form-control" id="EditEcuDate" required />
                    </div>

                    <div class="form-group">
                        <label for="BranchCodeEnc">Branch</label>
                        <select class="form-control" id="EditBranchCodeEnc" required></select>
                    </div>

                    <div class="form-group">
                        <label for="Findings">Findings</label>
                        <div class="form-group" id="editfindingsContainer">

                        </div>
                    </div>

                    <div class="form-group">
                        <label for="Remarks">Remarks</label>
                        <textarea class="form-control" id="EditRemarks"></textarea>
                    </div>

                    <hr />
                    <div class="form-group">
                        <label for="Summary">Summary:</label>
                        <div id="editfindingsSummary"></div>
                    </div>
                    <div id="editerrorList" class="text-danger mt-2"></div>


                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="confirmSaveDetailBtn" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#updateEcuConfirmationModal">Update Detail</button>
            </div>
        </div>
    </div>
</div>


<!-- Add Confirmation Modal -->
<div class="modal fade" id="addEcuConfirmationModal" tabindex="-1" aria-labelledby="addEcuConfirmationModalLabel" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addEcuConfirmationModalLabel">Confirm Save</h5>
                
            </div>
            <div class="modal-body">
                Are you sure you want to save this record?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="addEcuConfirmSaveBtn" class="btn btn-primary" onclick="submitEcuForm()">Continue</button>
            </div>
        </div>
    </div>
</div>

<!-- Update Confirmation Modal -->
<div class="modal fade" id="updateEcuConfirmationModal" tabindex="-1" aria-labelledby="updateEcuConfirmationModalLabel" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="updateEcuConfirmationModalLabel">Confirm Update</h5>

            </div>
            <div class="modal-body">
                Are you sure you want to update this record?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="updateEcuConfirmUpdateBtn" class="btn btn-primary" onclick="updateEcuForm()">Continue</button>
            </div>
        </div>
    </div>
</div>






