@using Newtonsoft.Json
@Html.AntiForgeryToken()
@model _VEHRSv1.Models.PemeReportViewModel
<style>
    input {
        text-transform: uppercase;
    }
</style>

<div class="container-fluid">
    <div class="card o-hidden border-0 shadow-lg my-4">
        <div class="card-body p-0">
            <div class="row">
                <div class="col-lg-12">
                    <div class="p-5">
                        <div class="text-center">
                            <h1 class="h4 text-gray-900 mb-4">Pre Employment Reports</h1>
                        </div>
                        <hr />
                        <!-- Display form-level validation errors -->
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                <ul>
                                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                    {
                                        <li>@error.ErrorMessage</li>
                                    }
                                </ul>
                            </div>
                        }
                        <div class="form-group row">
                            <div class="col-sm-4">
                                <label class="col-form-label-sm">Encoded Start Date</label>
                                <input type="date" class="form-control" asp-for="@Model.ReportParamG.EncodedStartDate" id="EncodedStartDate" name="EncodedStartDate" />
                                <span asp-validation-for="@Model.ReportParamG.EncodedStartDate" class="text-danger" style="display:none;"></span>
                            </div>
                            <div class="col-sm-4">
                                <label class="col-form-label-sm">Encoded End Date</label>
                                <input type="date" class="form-control" asp-for="@Model.ReportParamG.EncodedEndDate" id="EncodedEndDate" name="EncodedEndDate" />
                                <span asp-validation-for="@Model.ReportParamG.EncodedEndDate" class="text-danger" style="display:none;"></span>
                            </div>
                            <div class="col-sm-4">
                                <label class="col-form-label-sm">Status</label>
                                <select class="form-control" asp-for="@Model.ReportParamG.Status" id="Status" name="Status">
                                    <option></option>
                                </select>
                                <span asp-validation-for="@Model.ReportParamG.Status" class="text-danger" style="display:none;"></span>
                            </div>
                        </div>
                        <div class="form-group row">
                            <div class="col-sm-12 mt-1 ">
                                <button type="button" id="generatePemeReportPreviewBtn" class="btn btn-primary" onclick="generatePemeReportPreview()">Generate Report Preview</button>
                                <button type="button" id="downloadPemeReportExcel" class="btn btn-success">Export Report (Excel)</button>
                                <button type="button" id="downloadPemeReportPdf" class="btn btn-danger">Export Report (PDF)</button>
                            </div>

                        </div>

                        <hr />
                        <table class="table table-sm" id="pemeReportResult">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Full Name</th>
                                    <th>BirthDate</th>
                                    <th>Examination Date</th>
                                    <th>Medical Evaluator</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Initialize DataTable
            $('#pemeReportResult').DataTable({
                "processing": true,
                "searching": true,
                "ordering": false,
                "pageLength": 10,
                "lengthMenu": [5, 10, 50],
                "language": {
                    "emptyTable": "No records found"
                }
            });

            // Initialize select2 with data and set selected value if available
            $('#Status').select2({
                data: @Html.Raw(ViewBag.Status),
                placeholder: "Start typing to search...",
                allowClear: true,
                width: '100%'
            }).val('@Model.ReportParamG.Status').trigger('change');
        });




        function generatePemeReportPreview() {
            var token = $('input[name="__RequestVerificationToken"]').val();
            var startDate = $('#EncodedStartDate').val();
            var endDate = $('#EncodedEndDate').val();
            var status = $('#Status').val();

            $.ajax({
                url: "/Report/GeneratePemeReportPreview",
                type: 'POST', // Correct the method to POST
                headers: {
                    'RequestVerificationToken': token // Pass the anti-forgery token
                },
                data: {
                    EncodedStartDate: startDate,
                    EncodedEndDate: endDate,
                    Status: status
                },
                success: function (data) {
                    console.log(data);
;                    if (data.success) {
                        // Destroy the existing DataTable if it exists
                        if ($.fn.dataTable.isDataTable('#pemeReportResult')) {
                            $('#pemeReportResult').DataTable().clear().destroy();
                        }

                        // Clear the existing table body
                        var tableBody = $('#pemeReportResult tbody');
                        tableBody.empty();

                        // Populate the table with new data
                        data.returnToViewAsJson.PemeReportResults.forEach(function (result, index) {
                            var row = `
                                    <tr>
                                        <td>${index + 1}</td>
                                        <td>${result.fullName}</td>
                                        <td>${new Date(result.birthDate).toLocaleDateString()}</td>
                                        <td>${new Date(result.examDate).toLocaleDateString()}</td>
                                        <td>${result.medicalEvaluatorName}</td>
                                        <td>${result.status}</td>
                                    </tr>`;
                            tableBody.append(row);
                        });

                        // Reinitialize the DataTable with updated data
                        $('#pemeReportResult').DataTable({
                            paging: true,
                            searching: true,
                            ordering: false,
                            info: true,
                            destroy: true // Ensure proper reinitialization
                        });
                    } else {
                        // Display error messages
                        var errorMessages = data.errors;
                        // Clear existing error messages
                        $('span.text-danger').hide();

                        // Loop through the errors and show them next to the respective fields
                        errorMessages.forEach(function (error) {
                            if (error.includes('Status is required')) {
                                $('#Status').next('span').text(error).show();
                            }
                            if (error.includes('Encoded End Date is required')) {
                                $('#EncodedEndDate').next('span').text(error).show();
                            }
                            if (error.includes('Encoded Start Date is required')) {
                                $('#EncodedStartDate').next('span').text(error).show();
                            }
                        });

                        console.error("Failed to refresh table data:", errorMessages.join(", ") || "No error message provided.");
                    }
                },
                error: function (xhr) {
                    console.error("Error fetching updated data:", xhr.responseText || "An error occurred.");
                }
            });
        }

    </script>
}

