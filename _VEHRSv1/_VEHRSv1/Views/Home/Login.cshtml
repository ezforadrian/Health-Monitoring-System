@{
    Layout = "_LayoutWithoutMenu";
    ViewData["Title"] = "VEHRS";
}
<section>
    <div class="container-fluid h-custom">
        
        <div class="row d-flex justify-content-center align-items-center" style="padding-top:10%;">
            <div class="col-md-9 col-lg-7 col-xl-6 d-flex justify-content-center">
                <img src="~/img/VEHRS.jpg"
                     class="img-fluid rounded" alt="HSWMS"
                     style="width: 70%;">
            </div>

            <div class="col-md-9 col-lg-7 col-xl-4 border rounded" style="box-shadow: 1px 1px 1px 1px #b2b1b1">
                <center>
                <img src="~/img/Logo.png"
                         class="img-fluid rounded d-flex p-2" alt="HSWMS"
                     style="width: 15%; margin-top: 10%;">
                </center>
                <form id="loginForm" autocomplete="off">
                    @Html.AntiForgeryToken()

                    <div class="divider d-flex align-items-center my-4">
                        <p class="text-center fw-bold mx-3 mb-0">SIGN IN</p>

                    </div>

                    <div data-mdb-input-init class="form-outline mb-4">
                        <input type="text" id="username_" class="form-control form-control-lg"
                               placeholder="Enter Username" required />
                        <label class="form-label" for="username_">Username</label>
                    </div>


                    <div data-mdb-input-init class="form-outline mb-3">
                        <input type="password" id="password_" class="form-control form-control-lg"
                               placeholder="Enter password" required />
                        <label class="form-label" for="password_">Password</label>
                    </div>

                    <div class="text-center text-lg-start mt-4 pt-2">
                        <button type="submit" data-mdb-button-init data-mdb-ripple-init class="btn btn-primary btn-lg "
                                style="padding-left: 5%; padding-right: 5%; margin-left:40%;">
                            Login
                        </button>
                    </div>

                </form>
                <br>
            </div>
        </div>
    </div>
</section>

<!-- Modal HTML -->
<div id="errorModal" class="modal fade" role="dialog">
    <div class="modal-dialog">
        <!-- Modal content-->
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="errorModalTitle">Error</h5> <!-- Update this line -->
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p id="errorModalMessage"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>




<script src="~/js/Home/_homelogin.js"></script>
